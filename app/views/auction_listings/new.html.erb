<div class="min-h-screen">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <nav class="mb-8">
      <%= link_to donation_path(@donation), class: "inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Cancel
      <% end %>
    </nav>

    <article class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm mb-6">
      <header class="border-b border-gray-200 bg-gray-50/75 px-6 py-4">
        <h2 class="text-sm font-semibold text-gray-900">Donation Details (for reference)</h2>
      </header>
      <dl class="divide-y divide-gray-100">
        <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Short description</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @donation.short_description.presence || "—" %></dd>
        </div>
        <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Notes</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @donation.notes.presence || "—" %></dd>
        </div>
        <div class="px-6 py-4 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Fine print</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @donation.fine_print.presence || "—" %></dd>
        </div>
      </dl>
    </article>

    <article class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <header class="border-b border-gray-200 bg-gray-50/75 px-6 py-8">
        <h1 class="text-2xl font-bold tracking-tight text-gray-900">New Auction Listing</h1>
        <p class="mt-2 text-base text-gray-600">
          Create auction website listing for: <%= @donation.short_description %>
        </p>
      </header>

      <%= render "form" %>
    </article>
  </div>
</div>
