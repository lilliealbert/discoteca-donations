<div class="min-h-screen">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <nav class="mb-8">
      <%= link_to event_path(@donation.event), class: "inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to <%= @donation.event.name %>
      <% end %>
    </nav>

    <% if notice.present? %>
      <div class="mb-6 rounded-lg bg-green-50 p-4 border border-green-200">
        <p class="text-sm font-medium text-green-800"><%= notice %></p>
      </div>
    <% end %>

    <article class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <header class="border-b border-gray-200 bg-gray-50/75 px-6 py-8 sm:flex sm:items-center sm:justify-between">
        <div>
          <h1 class="text-2xl font-bold tracking-tight text-gray-900">Donation</h1>
          <p class="mt-2 text-base text-gray-600"><%= @donation.short_description %></p>
        </div>
        <% if policy(@donation).update? %>
          <div class="mt-4 sm:mt-0">
            <%= link_to edit_donation_path(@donation), class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
              </svg>
              Edit
            <% end %>
          </div>
        <% end %>
      </header>

      <dl class="divide-y divide-gray-100">
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Donor</dt>
          <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
            <%= link_to @donation.donor.name, donor_path(@donation.donor), class: "text-indigo-600 hover:text-indigo-500" %>
          </dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Event</dt>
          <dd class="mt-1 text-sm sm:col-span-2 sm:mt-0">
            <%= link_to @donation.event.name, event_path(@donation.event), class: "text-indigo-600 hover:text-indigo-500" %>
          </dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Volunteer</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @donation.volunteer&.email %></dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Type</dt>
          <dd class="mt-1 sm:col-span-2 sm:mt-0">
            <% type_classes = case @donation.donation_type
               when 'physical' then 'bg-blue-50 text-blue-700 ring-blue-600/20'
               when 'digital' then 'bg-purple-50 text-purple-700 ring-purple-600/20'
               when 'other' then 'bg-gray-50 text-gray-600 ring-gray-500/10'
               else 'bg-gray-50 text-gray-600 ring-gray-500/10'
               end %>
            <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset <%= type_classes %>">
              <%= @donation.donation_type&.humanize || 'Unknown' %>
            </span>
          </dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">In hand</dt>
          <dd class="mt-1 sm:col-span-2 sm:mt-0">
            <% if @donation.in_hand %>
              <span class="inline-flex items-center gap-1.5 text-sm text-green-600">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
                Yes, we have this donation
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1.5 text-sm text-gray-500">
                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                </svg>
                Not yet received
              </span>
            <% end %>
          </dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Short description</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @donation.short_description.presence || "No description" %></dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Notes</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @donation.notes.presence || "No notes" %></dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Fine print</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= @donation.fine_print.presence || "None" %></dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Created</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @donation.created_at.strftime("%B %d, %Y at %l:%M %p") %></dd>
        </div>
        <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
          <dt class="text-sm font-medium text-gray-500">Last updated</dt>
          <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= @donation.updated_at.strftime("%B %d, %Y at %l:%M %p") %></dd>
        </div>
      </dl>
    </article>

    <% if policy(@donation).manage_auction_listing? %>
      <article class="mt-8 overflow-hidden rounded-xl border border-yellow-200 bg-white shadow-sm">
        <header class="border-b border-yellow-200 bg-yellow-50/75 px-6 py-6 sm:flex sm:items-center sm:justify-between">
          <div>
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <h2 class="text-lg font-semibold text-gray-900">Auction Website Listing</h2>
              <span class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-800">Admin Only</span>
            </div>
            <p class="mt-1 text-sm text-gray-600">Details for the auction website</p>
          </div>
          <div class="mt-4 sm:mt-0">
            <% if @donation.auction_listing.present? %>
              <%= link_to edit_donation_auction_listing_path(@donation), class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors" do %>
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                </svg>
                Edit Listing
              <% end %>
            <% else %>
              <%= link_to new_donation_auction_listing_path(@donation), class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors" do %>
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Create Listing
              <% end %>
            <% end %>
          </div>
        </header>

        <% if @donation.auction_listing.present? %>
          <% listing = @donation.auction_listing %>
          <dl class="divide-y divide-gray-100">
            <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500">Title</dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= listing.title %></dd>
            </div>
            <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500">Category</dt>
              <dd class="mt-1 sm:col-span-2 sm:mt-0">
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-700 ring-1 ring-inset ring-gray-500/10">
                  <%= listing.category.humanize.titleize %>
                </span>
              </dd>
            </div>
            <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500">Status</dt>
              <dd class="mt-1 sm:col-span-2 sm:mt-0">
                <% status_classes = case listing.status
                   when 'draft' then 'bg-gray-100 text-gray-700 ring-gray-500/10'
                   when 'needs_review' then 'bg-yellow-100 text-yellow-800 ring-yellow-600/20'
                   when 'ready_for_export' then 'bg-green-100 text-green-800 ring-green-600/20'
                   else 'bg-gray-100 text-gray-700 ring-gray-500/10'
                   end %>
                <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium ring-1 ring-inset <%= status_classes %>">
                  <%= listing.status.humanize.titleize %>
                </span>
              </dd>
            </div>
            <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500">Short description</dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0"><%= listing.short_description.presence || "Not set" %></dd>
            </div>
            <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500">Long description</dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0 whitespace-pre-wrap"><%= listing.long_description.presence || "Not set" %></dd>
            </div>
            <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500">Estimated value</dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
                <% if listing.estimated_value.present? %>
                  <%= number_to_currency(listing.estimated_value) %>
                <% else %>
                  <span class="text-gray-400">Not set</span>
                <% end %>
              </dd>
            </div>
            <div class="px-6 py-5 sm:grid sm:grid-cols-3 sm:gap-4">
              <dt class="text-sm font-medium text-gray-500">Starting bid</dt>
              <dd class="mt-1 text-sm text-gray-900 sm:col-span-2 sm:mt-0">
                <% if listing.starting_bid.present? %>
                  <%= number_to_currency(listing.starting_bid) %>
                <% else %>
                  <span class="text-gray-400">Not set</span>
                <% end %>
              </dd>
            </div>
          </dl>

          <div class="border-t border-gray-100 px-6 py-4 bg-gray-50/50">
            <%= button_to "Delete Listing", donation_auction_listing_path(@donation),
                method: :delete,
                data: { turbo_confirm: "Are you sure you want to delete this auction listing?" },
                class: "rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition-colors" %>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">No auction listing</h3>
            <p class="mt-1 text-sm text-gray-500">Create a listing to add this donation to the auction website.</p>
          </div>
        <% end %>
      </article>
    <% end %>
  </div>
</div>