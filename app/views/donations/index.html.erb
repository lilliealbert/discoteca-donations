<div class="min-h-screen overflow-x-hidden">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <nav class="mb-8">
      <%= link_to event_path(@event), class: "inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to <%= @event.name %>
      <% end %>
    </nav>

    <article class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <header class="border-b border-gray-200 bg-gray-50/75 px-6 py-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold tracking-tight text-gray-900">Donations</h1>
            <p class="mt-2 text-base text-gray-600"><%= @event.name %> &mdash; <%= @donations.size %> confirmed donations</p>
          </div>
          <%= link_to event_export_auction_listings_path(@event), data: { turbo: false }, class: "inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            Export Auction Listings
          <% end %>
        </div>
      </header>
    </article>

    <div class="mt-8 overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full" data-controller="sortable-table">
        <thead class="sticky top-0 z-10">
          <tr class="border-b border-gray-200 bg-gray-50">
            <th scope="col" class="py-4 pl-6 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-600 cursor-pointer select-none group/header" data-sortable-table-target="header" data-action="click->sortable-table#sort">
              <span class="inline-flex items-center">
                Description
                <svg data-sort-icon class="ml-1 h-4 w-4 text-gray-400 opacity-0 group-hover/header:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                </svg>
              </span>
            </th>
            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-600 cursor-pointer select-none group/header" data-sortable-table-target="header" data-action="click->sortable-table#sort">
              <span class="inline-flex items-center">
                Donor
                <svg data-sort-icon class="ml-1 h-4 w-4 text-gray-400 opacity-0 group-hover/header:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                </svg>
              </span>
            </th>
            <th scope="col" class="hidden md:table-cell px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-600 cursor-pointer select-none group/header" data-sortable-table-target="header" data-action="click->sortable-table#sort">
              <span class="inline-flex items-center">
                Donor Type
                <svg data-sort-icon class="ml-1 h-4 w-4 text-gray-400 opacity-0 group-hover/header:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                </svg>
              </span>
            </th>
            <th scope="col" class="hidden md:table-cell px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-600 cursor-pointer select-none group/header" data-sortable-table-target="header" data-action="click->sortable-table#sort">
              <span class="inline-flex items-center">
                Volunteer
                <svg data-sort-icon class="ml-1 h-4 w-4 text-gray-400 opacity-0 group-hover/header:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                </svg>
              </span>
            </th>
            <th scope="col" class="hidden md:table-cell px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-600 cursor-pointer select-none group/header" data-sortable-table-target="header" data-action="click->sortable-table#sort">
              <span class="inline-flex items-center">
                Type
                <svg data-sort-icon class="ml-1 h-4 w-4 text-gray-400 opacity-0 group-hover/header:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                </svg>
              </span>
            </th>
            <th scope="col" class="hidden md:table-cell px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-600 cursor-pointer select-none group/header" data-sortable-table-target="header" data-action="click->sortable-table#sort">
              <span class="inline-flex items-center">
                In Hand
                <svg data-sort-icon class="ml-1 h-4 w-4 text-gray-400 opacity-0 group-hover/header:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                </svg>
              </span>
            </th>
            <th scope="col" class="hidden md:table-cell px-6 py-4 text-left text-xs font-semibold uppercase tracking-wide text-gray-600 cursor-pointer select-none group/header" data-sortable-table-target="header" data-action="click->sortable-table#sort">
              <span class="inline-flex items-center">
                Auction Listing
                <svg data-sort-icon class="ml-1 h-4 w-4 text-gray-400 opacity-0 group-hover/header:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                </svg>
              </span>
            </th>
            <th scope="col" class="relative py-4 pl-3 pr-6">
              <span class="sr-only">View</span>
            </th>
          </tr>
        </thead>
        <tbody data-sortable-table-target="body">
          <% if @donations.any? %>
            <% @donations.each_with_index do |donation, index| %>
              <tr class="<%= 'border-t border-gray-100' unless index.zero? %> hover:bg-gray-50/50 transition-colors">
                <td class="py-5 pl-6 pr-3">
                  <%= link_to donation_path(donation), class: "text-sm font-medium text-gray-900 hover:text-indigo-600" do %>
                    <%= donation.short_description %>
                  <% end %>
                </td>
                <td class="px-6 py-5">
                  <%= link_to donor_path(donation.donor), class: "text-sm text-indigo-600 hover:text-indigo-500" do %>
                    <%= donation.donor.name %>
                  <% end %>
                </td>
                <td class="hidden md:table-cell px-6 py-5">
                  <span class="text-sm text-gray-600"><%= Donor.donor_types[donation.donor.donor_type] || '—' %></span>
                </td>
                <td class="hidden md:table-cell px-6 py-5">
                  <span class="text-sm text-gray-600"><%= donation.volunteer.name || donation.volunteer&.email %></span>
                </td>
                <td class="hidden md:table-cell px-6 py-5">
                  <% type_classes = case donation.donation_type
                     when 'physical' then 'bg-blue-50 text-blue-700 ring-blue-600/20'
                     when 'digital' then 'bg-purple-50 text-purple-700 ring-purple-600/20'
                     when 'other' then 'bg-gray-50 text-gray-600 ring-gray-500/10'
                     else 'bg-gray-50 text-gray-600 ring-gray-500/10'
                     end %>
                  <span class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium ring-1 ring-inset <%= type_classes %>">
                    <%= donation.donation_type&.humanize || 'Unknown' %>
                  </span>
                </td>
                <td class="hidden md:table-cell px-6 py-5">
                  <% if donation.in_hand %>
                    <span class="inline-flex items-center gap-1 text-sm text-green-600">
                      <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                      </svg>
                      Yes
                    </span>
                  <% else %>
                    <span class="text-sm text-gray-400">No</span>
                  <% end %>
                </td>
                <td class="hidden md:table-cell px-6 py-5">
                  <% if donation.auction_listing.present? %>
                    <% status_classes = case donation.auction_listing.status
                       when 'draft' then 'bg-gray-100 text-gray-700 ring-gray-500/10'
                       when 'needs_review' then 'bg-yellow-100 text-yellow-800 ring-yellow-600/20'
                       when 'ready_for_export' then 'bg-green-100 text-green-800 ring-green-600/20'
                       else 'bg-gray-100 text-gray-700 ring-gray-500/10'
                       end %>
                    <span class="inline-flex items-center whitespace-nowrap rounded-full px-2 py-1 text-xs font-medium ring-1 ring-inset <%= status_classes %>">
                      <%= donation.auction_listing.status.humanize.titleize %>
                    </span>
                  <% else %>
                    <span class="text-sm text-gray-400">Not created</span>
                  <% end %>
                </td>
                <td class="py-5 pr-6 text-right">
                  <%= link_to donation_path(donation), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" do %>
                    View<span class="sr-only">, <%= donation.short_description %></span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="8" class="px-6 py-16 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 11.25v8.25a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-8.25M12 4.875A2.625 2.625 0 109.375 7.5H12m0-2.625V7.5m0-2.625A2.625 2.625 0 1114.625 7.5H12m0 0V21m-8.625-9.75h18c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125h-18c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                </svg>
                <h3 class="mt-4 text-sm font-semibold text-gray-900">No donations yet</h3>
                <p class="mt-1 text-sm text-gray-500">No donations have been confirmed for this event yet.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
